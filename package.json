{
    "name": "nudgenest-event-bus",
    "version": "1.0.0",
    "description": "event bus for nudgenest",
    "main": "build/server.js",
    "author": "Olujuwon Alabi",
    "license": "MIT",
    "scripts": {
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:unit": "jest src/__tests__/core",
        "test:integration": "jest src/__tests__/integration",
        "test:ci": "jest --ci --coverage --maxWorkers=2",
        "ngrok": "ngrok http 50001",
        "build": "tsc -p tsconfig.json",
        "start": "node build/server.js",
        "start-dev": "tsc -w & nodemon build/server.js",
        "dev": "npm-run-all -p start-dev",
        "format": "prettier --write .",
        "db-g": "npx prisma generate",
        "db-p": "npx prisma db push"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.859.0",
        "@aws-sdk/s3-request-presigner": "^3.859.0",
        "@hapi/hapi": "^21.4.2",
        "@hapi/inert": "^7.1.0",
        "@prisma/client": "^6.13.0",
        "@sendgrid/mail": "^8.1.5",
        "amqplib": "^0.10.8",
        "busboy": "^1.6.0",
        "dotenv": "^16.6.1",
        "hapi-alive": "^2.0.4",
        "hapi-pino": "^12.1.0",
        "jsonschema": "^1.5.0",
        "nodemailer": "^6.10.1",
        "ts-node": "^10.9.2",
        "twilio": "^5.8.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.32.0",
        "@hapi/shot": "^6.0.1",
        "@jest/globals": "^30.0.5",
        "@types/amqplib": "^0.10.7",
        "@types/busboy": "^1.5.4",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.17.0",
        "@types/nodemailer": "^6.4.17",
        "aws-sdk-client-mock": "^4.1.0",
        "eslint": "^9.32.0",
        "globals": "^15.15.0",
        "jest": "^30.0.5",
        "jest-mock-extended": "^4.0.0",
        "nodemon": "^3.1.10",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.6.2",
        "prisma": "^6.13.0",
        "ts-jest": "^29.4.1",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.39.0"
    }
}
