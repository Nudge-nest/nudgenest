// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/prisma/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Merchants {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  shopId         String           @unique
  domains        String
  currencyCode   String
  email          String           @unique
  name           String           @unique
  businessInfo   String           @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  address        Address
  Configurations Configurations[]
  Reviews        Reviews[]

  @@map("merchants")
}

model Reviews {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  merchantId    String   @db.ObjectId
  shopId        String
  customerEmail String
  customerPhone String
  customerName  String
  items         Json
  result        Json?
  verified      Boolean
  replies       Json?
  status        String   @default("Pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  merchant Merchants @relation(fields: [merchantId], references: [id])

  @@map("reviews")
}

model Configurations {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  merchantId   String           @unique @db.ObjectId
  emailContent EmailContent
  reminders    ReminderSettings
  publish      PublishSettings
  qrCode       QRSettings
  general      Json
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  merchant Merchants @relation(fields: [merchantId], references: [id])

  @@map("configs")
}

type Address {
  address1  String
  address2  String
  city      String
  country   String
  formatted Json
  zip       String
}

type Business {
  businessId       String
  address          Address[]
  billingAddress   Address[]
  plan             String
  shopDescription  String
  addressIsBilling Boolean
  contactEmail     String
}

type EmailContent {
  subject    String
  body       String
  buttonText String
}

type ReminderSettings {
  qty    String
  period String
}

type PublishSettings {
  autoPublish String
}

type QRSettings {
  url    String
  qrCode String
}

type ReviewSettings {
  timing       REVIEWTIMING
  replies      Boolean
  autoVerify   Boolean
  storeReviews Boolean
}

enum REVIEWTIMING {
  PURCHASE
  FULFILMENT
  DELIVERY
}
